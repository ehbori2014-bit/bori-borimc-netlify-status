BORIMC_ENV=development
BORIMC_DATABASE_PATH=../../database/borimc.sqlite3
BORIMC_SCHEMA_PATH=../../database/schema.sql

# Keep these private. Rotate before production use.
BORIMC_BOT_API_TOKEN=change-me-bot-token
BORIMC_PLUGIN_API_TOKEN=change-me-plugin-token
BORIMC_REGISTRATION_SECRET=change-me-registration-token
BORIMC_IP_HASH_SECRET=change-me-ip-hash-secret
BORIMC_ADMIN_SECRET=change-me-admin-secret
BORIMC_ADMIN_SESSION_SECRET=change-me-admin-session-secret

# Comma-separated Discord IDs. Owner is the top-level admin.
BORIMC_OWNER_DISCORD_IDS=123456789012345678
BORIMC_ADMIN_DISCORD_IDS=
BORIMC_OWNER_GOOGLE_EMAILS=
BORIMC_ADMIN_GOOGLE_EMAILS=

# Public URLs exposed through reverse proxy.
BORIMC_PUBLIC_URL=https://borimc.p-e.kr
BORIMC_ADMIN_URL=
BORIMC_API_URL=https://api.borimc.p-e.kr
BORIMC_INTERNAL_API_URL=http://127.0.0.1:4000
BORIMC_DRIVE_URL=https://drive.borimc.p-e.kr
BORIMC_MINECRAFT_ADDRESS=borimc.p-e.kr:10259

# Discord bot.
DISCORD_BOT_TOKEN=change-me-discord-bot-token
DISCORD_GUILD_ID=
BORIMC_RECORD_FORUM_CHANNEL_ID=

# Web OAuth login.
AUTH_SECRET=change-me-long-random-auth-secret
AUTH_URL=https://borimc.p-e.kr
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Web development helper only. Use a real session/OAuth adapter later.
BORIMC_WEB_DEMO_ROLE=guest
BORIMC_WEB_DEMO_PROVIDER=
BORIMC_WEB_DEMO_PROVIDER_SUBJECT=
BORIMC_WEB_DEMO_DISCORD_ID=
BORIMC_WEB_DEMO_GOOGLE_EMAIL=
